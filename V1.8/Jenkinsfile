pipeline {
    agent any

    stages {
        stage('Build Metadata') {
            steps {
                script {
                    env.START_TIME = new Date().format("yyyy-MM-dd HH:mm:ss")
                }
            }
        }

        stage('Generate Markdown Report') {
            steps {
                script {

                def report = """
                    # Jenkins Diagnostics Report

                    ## Build Information

                    | Item | Value |
                    |------|-------|
                    | Job | ${env.JOB_NAME} |
                    | Build | ${env.BUILD_NUMBER} |
                    | Node | ${env.NODE_NAME} |
                    | Workspace | ${env.WORKSPACE} |
                    | Build URL | ${env.BUILD_URL} |
                    | Started | ${env.START_TIME} |

                    ---

                    Generated by Jenkins Diagnostics Pipeline.
                    """

                    writeFile file: 'diagnostics.md', text: report
                }
            }
        }

        stage('Generate HTML Report') {
            steps {
                script {

                    def html = """
                    <html>

                    <head>
                    <title>Jenkins Diagnostics</title>
                    </head>

                    <body>

                    <h1>Jenkins Diagnostics Report</h1>

                    <table border="1" cellpadding="5">

                    <tr><td>Job</td><td>${env.JOB_NAME}</td></tr>
                    <tr><td>Build</td><td>${env.BUILD_NUMBER}</td></tr>
                    <tr><td>Node</td><td>${env.NODE_NAME}</td></tr>
                    <tr><td>Workspace</td><td>${env.WORKSPACE}</td></tr>
                    <tr><td>URL</td><td>${env.BUILD_URL}</td></tr>

                    </table>

                    </body>

                    </html>
                    """

                    writeFile file: 'diagnostics.html', text: html

                }
            }
        }

        stage('Generated Reports') {
            steps {

                sh '''
                ls -lh diagnostics.*
                '''

            }
        }

        stage('Archive Reports') {
            steps {

                archiveArtifacts(
                    artifacts: 'diagnostics.*',
                    fingerprint: true
                )

            }
        }

        stage('Publish HTML Report') {
            steps {

                publishHTML([
                    reportDir: '.',
                    reportFiles: 'diagnostics.html',
                    reportName: 'Diagnostics Report',
                    keepAll: true,
                    alwaysLinkToLastBuild: true,
                    allowMissing: false
                ])

            }
        }

        stage('Build Statistics') {
            steps {

                script {

                    echo "===================================="
                    echo "BUILD SUMMARY"
                    echo "===================================="

                    echo "Job      : ${env.JOB_NAME}"
                    echo "Build    : ${env.BUILD_NUMBER}"
                    echo "Node     : ${env.NODE_NAME}"
                    echo "Result   : ${currentBuild.currentResult}"
                    echo "URL      : ${env.BUILD_URL}"

                    echo "===================================="

                }

            }
        }
    }
}