import jenkins.model.Jenkins
node {
    try {
        stage('Jenkins Controller') {

            def j = Jenkins.instance
            def report = new StringBuffer()

            report << "=======================================\n"
            report << "JENKINS CONTROLLER\n"
            report << "=======================================\nn"

            report << "Version          : ${Jenkins.VERSION}\n"
            report << "Root URL         : ${j.rootUrl}\n"
            report << "Home             : ${j.rootDir}\n"
            report << "System Message   : ${j.systemMessage ?: 'Not Configured'}\n"

            report << ""

            report << "Jobs             : ${j.items.size()}\n"
            report << "Nodes            : ${j.nodes.size()}\n"
            report << "Executors        : ${j.numExecutors}\n"

            report << ""

            report << "Quiet Mode       : ${j.isQuietingDown()}\n"
            report << "Agent Port       : ${j.slaveAgentPort}\n"

            report << "======================================="

            println report.toString()
        }
    } catch (Exception e) {
        currentBuild.result = 'FAILURE'
        throw e
    }
    finally {
        echo "Pipeline completed: ${currentBuild.result ?: 'SUCCESS'}"
    }

}