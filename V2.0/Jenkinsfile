import jenkins.model.Jenkins
node {
    try {
        stage('Jenkins Controller') {

            def j = Jenkins.instance
            def report = new StringBuffer()

            report << "======================================="
            report << "JENKINS CONTROLLER"
            report << "======================================="

            report << "Version          : ${Jenkins.VERSION}"
            report << "Root URL         : ${j.rootUrl}"
            report << "Home             : ${j.rootDir}"
            report << "System Message   : ${j.systemMessage ?: 'Not Configured'}"

            report << ""

            report << "Jobs             : ${j.items.size()}"
            report << "Nodes            : ${j.nodes.size()}"
            report << "Executors        : ${j.numExecutors}"

            report << ""

            report << "Quiet Mode       : ${j.isQuietingDown()}"
            report << "Agent Port       : ${j.slaveAgentPort}"

            report << "======================================="

            println report.toString()
        }
    } catch (Exception e) {
        currentBuild.result = 'FAILURE'
        throw e
    }
    finally {
        echo "Pipeline completed: ${currentBuild.result ?: 'SUCCESS'}"
    }

}